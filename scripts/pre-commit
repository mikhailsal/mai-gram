#!/usr/bin/env bash
# Pre-commit hook: enforces code quality before every commit.
#
# Checks (in order, exits on first failure):
#   1. ruff lint               — no lint errors
#   2. ruff format             — all files formatted
#   3. mypy                    — no type errors
#   4. code size audit         — report oversized files/functions for refactoring
#   5. pytest + coverage       — all tests pass, coverage >= 90%
#   6. live functional pytest  — real OpenRouter-backed integration suite passes
#
# Install with:  make install-hooks
# Skip once with: git commit --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step() { printf "${YELLOW}▶ %s${NC}\n" "$1"; }
pass() { printf "${GREEN}✓ %s${NC}\n" "$1"; }
fail() { printf "${RED}✗ %s${NC}\n" "$1"; exit 1; }

# ── 1. Lint ──────────────────────────────────────────────────────
step "Checking lint (ruff check)"
if ruff check . --quiet; then
    pass "Lint clean"
else
    fail "Lint errors found — run 'make fix' to auto-fix"
fi

# ── 2. Format ────────────────────────────────────────────────────
step "Checking format (ruff format)"
if ruff format --check --quiet .; then
    pass "Formatting OK"
else
    fail "Formatting issues — run 'make format' to fix"
fi

# ── 3. Type check ────────────────────────────────────────────────
step "Type checking (mypy)"
if mypy src/mai_gram --no-error-summary 2>/dev/null; then
    pass "Type check passed"
else
    fail "Type errors found — run 'mypy src/mai_gram' for details"
fi

# ── 4. Code size audit ──────────────────────────────────────────
step "Auditing code size limits"
if python3 scripts/check_code_limits.py; then
    pass "Code size audit completed (report-only)"
else
    fail "Code size audit failed"
fi

# ── 5. Tests + coverage ─────────────────────────────────────────
step "Running tests with coverage"
if pytest --cov=mai_gram --cov-config=pyproject.toml --cov-fail-under=90 -q 2>&1; then
    pass "All tests passed with coverage ≥ 90%"
else
    fail "Tests failed or coverage below 90%"
fi

# ── 6. Live functional tests ────────────────────────────────────
step "Running live functional tests"
if make test-functional-live; then
    pass "Live functional tests passed"
else
    fail "Live functional tests failed"
fi

printf "\n${GREEN}All pre-commit checks passed!${NC}\n"
