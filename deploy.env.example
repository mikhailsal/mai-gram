# Deployment configuration for scripts/deploy.sh (used by `make deploy`).
#
# Copy this file to `deploy.env` and fill in the real values for YOUR server.
# `deploy.env` is gitignored and MUST stay out of the repository.
#
# This assumes the app runs inside an LXD system container on the remote host,
# as a nested Docker Compose stack. See docs/deploy.md for the full picture.

# SSH destination for the server (an alias from ~/.ssh/config, or user@host).
DEPLOY_SSH_HOST=my-server

# Name of the LXD container on the host that runs the bots.
DEPLOY_LXD_CONTAINER=mai-telegram

# Application directory inside the container.
DEPLOY_APP_DIR=/opt/mai-telegram

# Staging directory on the host (outside the container), relative to $HOME.
DEPLOY_STAGING_DIR=.deploy-staging/mai-telegram

# Directory on the host for pre-deploy data/ backups (the chat-history tarball).
DEPLOY_HDD_BACKUP_DIR=/var/backups/mai-telegram

# How many pre-deploy snapshots + host tarballs to keep (older ones pruned).
DEPLOY_KEEP_BACKUPS=5

# Max seconds to wait for the LXD snapshot. If it exceeds this, the snapshot is
# abandoned and the deploy continues (the portable data/ tarball is the primary
# rollback artifact). Raise it if your host's LXD snapshots are slow; see
# docs/deploy.md for why that happens and how to speed it up.
DEPLOY_SNAPSHOT_TIMEOUT=300

# Uncomment to skip the "local git tree is dirty" warning.
# DEPLOY_ALLOW_DIRTY=1
