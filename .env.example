# mAI Companion Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# REQUIRED SETTINGS
# ==============================================================================

# Telegram Bot API token from @BotFather
# Get it by messaging https://t.me/BotFather and creating a new bot
TELEGRAM_BOT_TOKEN=

# OpenRouter API key from https://openrouter.ai
# Create an account, add credits, and generate an API key
OPENROUTER_API_KEY=

# ==============================================================================
# SECURITY (Highly Recommended)
# ==============================================================================

# Comma-separated list of Telegram user IDs allowed to use the AI
# Get your ID by messaging https://t.me/userinfobot
# Leave empty to allow anyone (NOT RECOMMENDED - anyone can use your API credits)
ALLOWED_USERS=

# ==============================================================================
# LLM SETTINGS
# ==============================================================================

# LLM model identifier on OpenRouter
# See https://openrouter.ai/models for available models
# Recommended: openai/gpt-4o, anthropic/claude-3.5-sonnet
LLM_MODEL=openai/gpt-4o

# ==============================================================================
# TIME SETTINGS
# ==============================================================================

# IANA timezone for proactive messaging and quiet hours
# Examples: America/New_York, Europe/London, Asia/Tokyo
TIMEZONE=UTC

# Quiet hours - AI won't send proactive messages during this time
# Values are hours in 24-hour format (0-23)
QUIET_HOURS_START=23
QUIET_HOURS_END=7

# ==============================================================================
# MEMORY SETTINGS
# ==============================================================================

# Minimum messages per day before daily summarization triggers
SUMMARY_THRESHOLD=20

# Maximum wiki entries to include in prompt context
WIKI_CONTEXT_LIMIT=20

# Number of recent messages to include in short-term context
SHORT_TERM_LIMIT=30

# Maximum agentic tool-calling iterations per response
TOOL_MAX_ITERATIONS=5

# ==============================================================================
# DATABASE SETTINGS
# ==============================================================================

# SQLAlchemy async database URL
# Default: SQLite in the data directory
DATABASE_URL=sqlite+aiosqlite:///./data/mai_companion.db

# ChromaDB vector store directory
CHROMA_PERSIST_DIR=./data/chroma_data

# Base directory for wiki and summary files
MEMORY_DATA_DIR=./data

# ==============================================================================
# DEBUG SETTINGS (Development Only)
# ==============================================================================

# Enable debug mode (verbose logging, SQL echo)
# WARNING: May log sensitive data - don't enable in production
DEBUG=false

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
