# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (get from https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default LLM model (via OpenRouter)
LLM_MODEL=openai/gpt-4o

# Database path (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/mai_companion.db

# ChromaDB storage path
CHROMA_PERSIST_DIR=./data/chroma_data

# Logging level
LOG_LEVEL=INFO

# Timezone for the companion (used for proactive messaging, quiet hours, etc.)
TIMEZONE=UTC

# Quiet hours (companion will not send proactive messages during these hours)
QUIET_HOURS_START=23
QUIET_HOURS_END=7
